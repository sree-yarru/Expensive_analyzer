ORDER_TAB_TRACKER="order_tracker"
ORDER_TAB_SUMMARY="Order_Summary"

# Extraction config
ORDER_EXTRACTION_CONFIG="extraction_config_orders.json"

# ── Alectra Utilities Bill Agent settings ──
