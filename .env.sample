# Historical parameters for email_history_agent.py
HISTORY_SENDER="sender_email@example.com"
HISTORY_START_DATE="2023-01-01"
HISTORY_END_DATE="2026-03-18"

# Sheet & Tab config (defaults to SHEET_URL if not set)
HISTORY_SHEET_URL="your_history_sheet_url_here"
HISTORY_TAB_DETAILS="Tennis_history"
HISTORY_TAB_TRACKER="Tennis_history_tracker"
HISTORY_TAB_SUMMARY="Tennis_history_summary"

# ── Email Order Agent settings ──
